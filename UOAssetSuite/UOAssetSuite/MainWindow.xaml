<Window x:Class="UOAssetSuite.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:UOAssetSuite.Views"
        Title="Ultima Online Asset Suite"
        Height="720"
        Width="1100"
        MinHeight="520"
        MinWidth="900">
    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16" Background="#202733">
            <StackPanel>
                <TextBlock Text="Ultima Online Asset Suite" FontSize="24" FontWeight="SemiBold" Foreground="White" />
                <TextBlock Text="Manage UO client art, landtiles, animations, gumps, maps, and tiledata with UOFiddler-compatible workflows." Foreground="#D7DEE8" />
            </StackPanel>
        </Border>
        <TabControl Margin="12">
            <TabItem Header="Art"><views:ArtView DataContext="{Binding Art}" /></TabItem>
            <TabItem Header="Landtiles"><views:LandtilesView DataContext="{Binding Landtiles}" /></TabItem>
            <TabItem Header="Animations"><views:AnimationsView DataContext="{Binding Animations}" /></TabItem>
            <TabItem Header="Gumps"><views:GumpsView DataContext="{Binding Gumps}" /></TabItem>
            <TabItem Header="Maps"><views:MapsView DataContext="{Binding Maps}" /></TabItem>
            <TabItem Header="Tiledata"><views:TiledataView DataContext="{Binding Tiledata}" /></TabItem>
        </TabControl>
    </DockPanel>
</Window>
