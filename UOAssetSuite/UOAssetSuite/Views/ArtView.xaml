<UserControl x:Class="UOAssetSuite.Views.ArtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Status}" Margin="0,8,0,0" />
            <WrapPanel Margin="0,16,0,0">
                <Button Content="Load UO Client Directory" Command="{Binding LoadClientDirectoryCommand}" Margin="0,0,8,8" Padding="10,4" />
                <Button Content="Export Selected" Command="{Binding ExportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" />
                <Button Content="Import / Replace Selected" Command="{Binding ImportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" />
                <Button Content="Save Modified Data" Command="{Binding SaveModifiedDataCommand}" Margin="0,0,8,8" Padding="10,4" />
            </WrapPanel>
            <GroupBox Header="Bitmap preview" Margin="0,12,0,0">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Left" Width="220">
                        <TextBlock Text="Art ID" />
                        <TextBox Text="{Binding AssetId, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,8" />
                        <CheckBox Content="Land tile" IsChecked="{Binding IsLandTile}" Margin="0,0,0,8" />
                        <Button Content="Preview Bitmap" Command="{Binding PreviewCommand}" Padding="10,4" />
                    </StackPanel>
                    <Image Source="{Binding PreviewImage}" Width="160" Height="160" Stretch="Uniform" Margin="16,0" />
                    <TextBox Text="{Binding PreviewText}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </GroupBox>
        </StackPanel>
    </Grid>
</UserControl>
