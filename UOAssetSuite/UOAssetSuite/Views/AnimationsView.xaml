<UserControl x:Class="UOAssetSuite.Views.AnimationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12"><StackPanel><TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" /><TextBlock Text="{Binding Status}" Margin="0,8,0,0" /><WrapPanel Margin="0,16,0,0"><Button Content="Load UO Client Directory" Command="{Binding LoadClientDirectoryCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Export Selected" Command="{Binding ExportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Import / Replace Selected" Command="{Binding ImportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Save Modified Data" Command="{Binding SaveModifiedDataCommand}" Margin="0,0,8,8" Padding="10,4" /></WrapPanel><GroupBox Header="Animation preview" Margin="0,12,0,0"><StackPanel Margin="8"><WrapPanel><TextBlock Text="Body" VerticalAlignment="Center"/><TextBox Text="{Binding BodyId, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="4,0,12,0"/><TextBlock Text="Action" VerticalAlignment="Center"/><TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="4,0,12,0"/><TextBlock Text="Direction" VerticalAlignment="Center"/><TextBox Text="{Binding Direction, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="4,0,12,0"/><Button Content="Preview Animation" Command="{Binding PreviewCommand}" Padding="10,4"/></WrapPanel><TextBox Text="{Binding PreviewText}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="220" Margin="0,12,0,0"/></StackPanel></GroupBox></StackPanel></Grid>
</UserControl>
