<UserControl x:Class="UOAssetSuite.Views.LandtilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Status}" Margin="0,8,0,0" />
            <TextBlock Text="Import, export, preview, and edit workflows will be implemented here." Margin="0,16,0,0" Foreground="#58606A" />
        </StackPanel>
    </Grid>
</UserControl>
