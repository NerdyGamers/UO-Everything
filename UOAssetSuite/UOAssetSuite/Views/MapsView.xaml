<UserControl x:Class="UOAssetSuite.Views.MapsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12"><StackPanel><TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" /><TextBlock Text="{Binding Status}" Margin="0,8,0,0" /><WrapPanel Margin="0,16,0,0"><Button Content="Load UO Client Directory" Command="{Binding LoadClientDirectoryCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Export Selected" Command="{Binding ExportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Import / Replace Selected" Command="{Binding ImportSelectedAssetsCommand}" Margin="0,0,8,8" Padding="10,4" /><Button Content="Save Modified Data" Command="{Binding SaveModifiedDataCommand}" Margin="0,0,8,8" Padding="10,4" /></WrapPanel><GroupBox Header="Map tile preview" Margin="0,12,0,0"><StackPanel Margin="8"><WrapPanel><ComboBox ItemsSource="{Binding Maps}" SelectedItem="{Binding Map}" Width="120" Margin="0,0,12,0"/><TextBlock Text="X" VerticalAlignment="Center"/><TextBox Text="{Binding X, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="4,0,12,0"/><TextBlock Text="Y" VerticalAlignment="Center"/><TextBox Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}" Width="70" Margin="4,0,12,0"/><Button Content="Preview Tile" Command="{Binding PreviewCommand}" Padding="10,4"/></WrapPanel><TextBox Text="{Binding PreviewText}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="260" Margin="0,12,0,0"/></StackPanel></GroupBox></StackPanel></Grid>
</UserControl>
